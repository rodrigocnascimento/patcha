{
  "name": "patcha",
  "version": "0.7.1",
  "description": "CLI para scanning e remediation de vulnerabilidades em dependências npm",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "patcha": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --no-warnings --loader tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "opencode:compile": "node scripts/opencode-compile.mjs"
  },
  "keywords": [
    "security",
    "vulnerabilities",
    "npm",
    "audit",
    "dependencies"
  ],
  "author": "Rodrigo Nascimento <rodrigocnascimento@gmail.com>",
  "homepage": "https://patcha.site",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/rodrigocnascimento/patcha"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/prompts": "^2.4.9",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@google/generative-ai": "^0.21.0",
    "@npmcli/arborist": "^7.3.1",
    "commander": "^11.1.0",
    "cosmiconfig": "^9.0.1",
    "dotenv": "^17.3.1",
    "openai": "^4.77.0",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "prompts": "^2.4.2",
    "undici": "^7.24.3",
    "zod": "^3.24.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "ajv": "8.18.0"
  }
}
