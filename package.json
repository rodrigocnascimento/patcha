{
  "name": "patcha",
  "version": "0.1.0",
  "description": "CLI para scanning e remediation de vulnerabilidades em dependências npm",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "patcha": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "security",
    "vulnerabilities",
    "npm",
    "audit",
    "dependencies"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "commander": "^11.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
