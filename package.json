{
  "name": "patcha",
  "version": "0.2.0",
  "description": "CLI para scanning e remediation de vulnerabilidades em dependências npm",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "patcha": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "security",
    "vulnerabilities",
    "npm",
    "audit",
    "dependencies"
  ],
  "author": "Rodrigo Nascimento <rodrigocnascimento@gmail.com>",
  "homepage": "https://patcha.site",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/rodrigocnascimento/patcha"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "@npmcli/arborist": "^7.3.1",
    "commander": "^11.1.0",
    "dotenv": "^17.3.1",
    "picocolors": "^1.0.0",
    "undici": "^7.24.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
